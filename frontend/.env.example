# =============================================================================
# YorkPulse Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEXT_PUBLIC_ variables are exposed to the browser — never put secrets here.

# Backend FastAPI URL
# Local dev:  http://localhost:8000
# Production: your deployed backend URL (Railway / Render / Fly.io / etc.)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase — used for real-time messaging subscriptions (client-side)
# Get these from your Supabase project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
